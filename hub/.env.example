# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/piratesocial"

# GitHub OAuth
GITHUB_CLIENT_ID="your_github_oauth_app_client_id"
GITHUB_CLIENT_SECRET="your_github_oauth_app_client_secret"

# JWT
JWT_SECRET="change-this-to-a-long-random-string"

# Server
PORT=3000
HUB_URL="http://localhost:3000"

# CORS - comma-separated allowed origins (user node domains)
CORS_ORIGINS="http://localhost:4321,http://localhost:8080"

# Feed aggregation interval in minutes
FEED_POLL_INTERVAL=10
