---
import ProfileBlock from './blocks/ProfileBlock.astro';
import RecentPostsBlock from './blocks/RecentPostsBlock.astro';
import HeroBlock from './blocks/HeroBlock.astro';
import YouTubeBlock from './blocks/YouTubeBlock.astro';
import GalleryBlock from './blocks/GalleryBlock.astro';
import TextBlock from './blocks/TextBlock.astro';
import ImageBlock from './blocks/ImageBlock.astro';
import LocationBlock from './blocks/LocationBlock.astro';
import YouTubePlayer from './YouTubePlayer.jsx';

const { blocks = [] } = Astro.props;

const hasLightbox = blocks.some((b: any) => b.type === 'gallery' || (b.type === 'image' && b.lightbox !== false));

// Separate floating YouTube players — they'll be rendered with transition:persist
const floatingPlayers = blocks.filter((b: any) => b.type === 'youtube' && b.display === 'floating');
---

{blocks.map((block: any) => (
  <>
    {block.type === 'hero' && <HeroBlock {...block} />}
    {block.type === 'profile' && <ProfileBlock {...block} />}
    {block.type === 'recentPosts' && <RecentPostsBlock {...block} />}
    {block.type === 'youtube' && <YouTubeBlock {...block} />}
    {block.type === 'gallery' && <GalleryBlock {...block} />}
    {block.type === 'text' && <TextBlock {...block} />}
    {block.type === 'image' && <ImageBlock {...block} />}
    {block.type === 'location' && <LocationBlock {...block} />}
  </>
))}

{/* Floating players — persisted across page navigations */}
{floatingPlayers.map((block: any, i: number) => (
  <div transition:persist={`floating-player-${i}`}>
    <YouTubePlayer
      client:load
      url={block.url}
      heading={block.heading}
      caption={block.caption}
      audioOnly={block.audioOnly}
      display="floating"
      tracks={block.tracks}
      layout={block.layout}
    />
  </div>
))}

{hasLightbox && (
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/glightbox/dist/css/glightbox.min.css" />
  <script is:inline src="https://cdn.jsdelivr.net/npm/glightbox/dist/js/glightbox.min.js"></script>
  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      if (typeof GLightbox !== 'undefined') {
        GLightbox({ selector: '.glightbox', touchNavigation: true, loop: true });
      }
    });
  </script>
)}
