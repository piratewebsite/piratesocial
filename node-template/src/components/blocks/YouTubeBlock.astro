---
import YouTubePlayer from '../YouTubePlayer.jsx';

const { url, heading, caption, audioOnly, display = 'docked', tracks, layout = 'contained' } = Astro.props;

// Floating players are rendered separately in BaseLayout with transition:persist
const isFloating = display === 'floating';
---

{!isFloating && (
  <YouTubePlayer
    client:visible
    url={url}
    heading={heading}
    caption={caption}
    audioOnly={audioOnly}
    display="docked"
    tracks={tracks}
    layout={layout}
  />
)}
