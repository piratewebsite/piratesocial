---
const { platform, handle, embedCode, heading } = Astro.props;
---

<section class="mb-12">
  {heading && (
    <h2 class="text-2xl font-bold font-heading mb-4 px-4">{heading}</h2>
  )}

  {platform === 'x' && handle && (
    <div class="max-w-lg mx-auto">
      <a
        class="twitter-timeline"
        data-theme="dark"
        href={`https://twitter.com/${handle.replace(/^@/, '')}`}
      >
        Tweets by @{handle.replace(/^@/, '')}
      </a>
      <script is:inline>
        // If widgets.js already ran, manually trigger it to pick up new anchors.
        // Otherwise inject the script for the first time.
        if (window.twttr && window.twttr.widgets) {
          window.twttr.widgets.load();
        } else {
          var _s = document.createElement('script');
          _s.src = 'https://platform.twitter.com/widgets.js';
          _s.async = true;
          _s.charset = 'utf-8';
          document.head.appendChild(_s);
        }
      </script>
    </div>
  )}

  {platform === 'facebook' && handle && (
    <div class="flex justify-center">
      <div id="fb-root"></div>
      <div
        class="fb-page"
        data-href={`https://www.facebook.com/${handle.replace(/^@/, '')}`}
        data-tabs="timeline"
        data-width="500"
        data-height="600"
        data-small-header="true"
        data-adapt-container-width="true"
        data-hide-cover="false"
        data-show-facepile="false"
      ></div>
      <script is:inline>
        (function(d, s, id) {
          var js, fjs = d.getElementsByTagName(s)[0];
          if (d.getElementById(id)) return;
          js = d.createElement(s); js.id = id;
          js.src = "https://connect.facebook.net/en_US/sdk.js#xfbml=1&version=v19.0";
          fjs.parentNode.insertBefore(js, fjs);
        }(document, 'script', 'facebook-jssdk'));
      </script>
    </div>
  )}

  {platform === 'instagram' && handle && (
    <div class="max-w-2xl mx-auto px-4 text-center">
      <p class="text-theme-muted mb-3">
        Follow <a
          class="text-theme-primary underline font-medium"
          href={`https://www.instagram.com/${handle.replace(/^@/, '')}`}
          target="_blank"
          rel="noopener noreferrer"
        >@{handle.replace(/^@/, '')}</a> on Instagram
      </p>
      <a
        href={`https://www.instagram.com/${handle.replace(/^@/, '')}`}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-lg border border-theme-border bg-theme-card px-5 py-3 text-sm font-medium hover:bg-theme-card-hover transition"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
        View on Instagram
      </a>
      <p class="mt-3 text-xs text-theme-faint">Instagram does not allow embedding feeds on external sites.</p>
    </div>
  )}

  {platform === 'custom' && embedCode && (
    <div class="max-w-2xl mx-auto px-4 overflow-hidden rounded-lg" set:html={embedCode} />
  )}
</section>
