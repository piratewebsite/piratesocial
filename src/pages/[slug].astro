---
import BaseLayout from '../layouts/BaseLayout.astro';
import BlockRenderer from '../components/BlockRenderer.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { withBase } from '../lib/config';

export async function getStaticPaths() {
  const pages = await getCollection('pages');
  // Exclude 'home' — that's handled by index.astro
  return pages
    .filter((p: CollectionEntry<'pages'>) => p.data.slug !== 'home')
    .map((p: CollectionEntry<'pages'>) => ({ params: { slug: p.data.slug }, props: { page: p } }));
}

interface Props { page: CollectionEntry<'pages'>; }
const { page } = Astro.props as Props;

// OG image: explicit page override → the page's first hero image → (layout
// falls back to the site default in pwa.json).
const heroImage = (page.data.blocks || []).find(
  (b: any) => b.type === 'hero' && b.image
)?.image;
const ogImage = page.data.ogImage || heroImage;
---

<BaseLayout
  title={page.data.title}
  description={page.data.description}
  image={ogImage ? withBase(ogImage) : undefined}
>
  <BlockRenderer blocks={page.data.blocks || []} />
</BaseLayout>
